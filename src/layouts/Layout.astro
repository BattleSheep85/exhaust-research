---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AI-powered product research that goes deeper than any search engine.', ogImage } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title} | Exhaust Research</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | Exhaust Research`} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Exhaust Research`} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="border-b border-surface-800 bg-surface-950/80 backdrop-blur-xl sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-8 h-8 rounded-lg bg-primary-600 flex items-center justify-center text-white font-bold text-sm group-hover:bg-primary-500 transition-colors">
              ER
            </div>
            <span class="font-bold text-lg text-white">Exhaust Research</span>
          </a>
          <div class="flex items-center gap-6">
            <a href="/research" class="text-surface-400 hover:text-white transition-colors text-sm font-medium">Browse</a>
            <a href="/blog" class="text-surface-400 hover:text-white transition-colors text-sm font-medium">Blog</a>
            <a href="/about" class="text-surface-400 hover:text-white transition-colors text-sm font-medium">About</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-surface-800 py-12 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-6 h-6 rounded bg-primary-600 flex items-center justify-center text-white font-bold text-xs">ER</div>
            <span class="text-surface-500 text-sm">Exhaust Research &mdash; AI-powered product intelligence</span>
          </div>
          <div class="flex items-center gap-6 text-sm text-surface-500">
            <a href="/research" class="hover:text-white transition-colors">Research</a>
            <a href="/blog" class="hover:text-white transition-colors">Blog</a>
            <a href="/about" class="hover:text-white transition-colors">About</a>
          </div>
        </div>
        <p class="text-center text-surface-600 text-xs mt-8">
          Product data is gathered from public sources. Affiliate links may earn commission at no cost to you.
        </p>
      </div>
    </footer>
  </body>
</html>
