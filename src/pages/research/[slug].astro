---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import { getDb } from '../../lib/db';
import { research, products } from '../../../db/schema';
import { eq, asc, sql } from 'drizzle-orm';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/research');

const db = getDb(Astro.locals.runtime.env.DB);

// Get the research entry
const [entry] = await db
  .select()
  .from(research)
  .where(eq(research.slug, slug))
  .limit(1);

if (!entry) {
  return new Response('Research not found', { status: 404 });
}

// Increment view count
await db
  .update(research)
  .set({ viewCount: sql`${research.viewCount} + 1` })
  .where(eq(research.id, entry.id));

// Get products sorted by rank
const productList = await db
  .select()
  .from(products)
  .where(eq(products.researchId, entry.id))
  .orderBy(asc(products.rank));

const isProcessing = entry.status === 'pending' || entry.status === 'processing';
const isFailed = entry.status === 'failed';

function parseJson<T>(json: string | null, fallback: T): T {
  if (!json) return fallback;
  try { return JSON.parse(json) as T; } catch { return fallback; }
}

const resultData = parseJson<{ methodology?: string; lastUpdated?: string }>(entry.result, {});
const sourceList = parseJson<string[]>(entry.sources, []);
---

<Layout title={entry.query} description={entry.summary ?? undefined}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="mb-8">
      <a href="/research" class="text-surface-500 hover:text-surface-300 text-sm transition-colors mb-4 inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        All research
      </a>

      <h1 class="text-3xl sm:text-4xl font-extrabold text-white mt-3 mb-4">{entry.query}</h1>

      {entry.category && (
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary-600/20 text-primary-400 mr-2">
          {entry.category}
        </span>
      )}

      <div class="flex items-center gap-4 mt-4 text-sm text-surface-500">
        <span>{entry.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        <span>{entry.viewCount} views</span>
        <span>{productList.length} products compared</span>
      </div>
    </div>

    {isProcessing && (
      <div class="bg-surface-900 border border-primary-600/30 rounded-xl p-8 text-center mb-8">
        <div class="animate-spin w-10 h-10 border-4 border-primary-600 border-t-transparent rounded-full mx-auto mb-4"></div>
        <h2 class="text-xl font-semibold text-white mb-2">Researching...</h2>
        <p class="text-surface-400">Scraping sources and analyzing products. This usually takes 15-30 seconds.</p>
        <p class="text-surface-500 text-sm mt-3">This page will auto-refresh.</p>
        <meta http-equiv="refresh" content="5" />
      </div>
    )}

    {isFailed && (
      <div class="bg-danger/10 border border-danger/30 rounded-xl p-6 mb-8">
        <h2 class="text-lg font-semibold text-danger mb-2">Research failed</h2>
        <p class="text-surface-400">Something went wrong during the analysis. This could be due to insufficient data from sources or a temporary API issue.</p>
        <a href={`/research/new?q=${encodeURIComponent(entry.query)}`} class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-primary-600 hover:bg-primary-500 text-white text-sm font-semibold rounded-lg transition-colors">
          Try again
        </a>
      </div>
    )}

    {/* Summary */}
    {entry.summary && (
      <div class="bg-surface-900 border border-surface-800 rounded-xl p-6 mb-8">
        <h2 class="text-lg font-semibold text-white mb-3">Summary</h2>
        <p class="text-surface-300 leading-relaxed">{entry.summary}</p>
      </div>
    )}

    {/* Products */}
    {productList.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-white mb-6">Products compared</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
          {productList.map((product) => (
            <ProductCard
              name={product.name}
              brand={product.brand}
              price={product.price}
              rating={product.rating}
              pros={parseJson<string[]>(product.pros, [])}
              cons={parseJson<string[]>(product.cons, [])}
              verdict={product.verdict}
              rank={product.rank}
              bestFor={product.bestFor}
              affiliateUrl={product.affiliateUrl}
              specs={parseJson<Record<string, string>>(product.specs, {})}
            />
          ))}
        </div>
      </section>
    )}

    {/* Methodology & Sources */}
    {(resultData.methodology || sourceList.length > 0) && (
      <div class="bg-surface-900 border border-surface-800 rounded-xl p-6 mb-8">
        {resultData.methodology && (
          <div class="mb-4">
            <h3 class="text-sm font-semibold text-surface-400 uppercase tracking-wide mb-2">Methodology</h3>
            <p class="text-surface-300 text-sm">{resultData.methodology}</p>
          </div>
        )}
        {sourceList.length > 0 && (
          <div>
            <h3 class="text-sm font-semibold text-surface-400 uppercase tracking-wide mb-2">Sources ({sourceList.length})</h3>
            <ul class="space-y-1">
              {sourceList.map((url) => (
                <li>
                  <a href={url} target="_blank" rel="noopener noreferrer" class="text-primary-400 hover:text-primary-300 text-sm transition-colors break-all">
                    {url}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}

    {/* Related search */}
    <div class="mt-12 pt-8 border-t border-surface-800">
      <h2 class="text-lg font-semibold text-white mb-4">Research something else</h2>
      <SearchBar size="compact" />
    </div>
  </div>
</Layout>
