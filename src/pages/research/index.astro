---
import Layout from '../../layouts/Layout.astro';
import SearchBar from '../../components/SearchBar.astro';
import ResearchCard from '../../components/ResearchCard.astro';
import { getDb } from '../../lib/db';
import { research } from '../../../db/schema';
import { desc, eq, like, sql } from 'drizzle-orm';

const db = getDb(Astro.locals.runtime.env.DB);
const searchQuery = Astro.url.searchParams.get('q') ?? '';
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10));
const perPage = 12;
const offset = (page - 1) * perPage;

const baseCondition = eq(research.status, 'complete');

const allResearch = await db
  .select({
    id: research.id,
    slug: research.slug,
    query: research.query,
    summary: research.summary,
    category: research.category,
    viewCount: research.viewCount,
    createdAt: research.createdAt,
    productCount: sql<number>`(SELECT COUNT(*) FROM products WHERE products.research_id = ${research.id})`,
  })
  .from(research)
  .where(searchQuery
    ? sql`${research.status} = 'complete' AND ${research.query} LIKE ${'%' + searchQuery + '%'}`
    : baseCondition
  )
  .orderBy(desc(research.createdAt))
  .limit(perPage)
  .offset(offset);
---

<Layout title="Browse Research">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-white mb-4">Browse research</h1>
      <p class="text-surface-400 mb-6">Explore past product research or start your own.</p>
      <SearchBar size="compact" placeholder="Search past research or start new..." />
    </div>

    {searchQuery && (
      <div class="mb-6 flex items-center gap-2">
        <span class="text-surface-400 text-sm">Results for:</span>
        <span class="px-3 py-1 rounded-full bg-primary-600/20 text-primary-400 text-sm font-medium">{searchQuery}</span>
        <a href="/research" class="text-surface-500 hover:text-surface-300 text-sm ml-2 transition-colors">Clear</a>
      </div>
    )}

    {allResearch.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {allResearch.map((r) => (
          <ResearchCard
            slug={r.slug}
            query={r.query}
            summary={r.summary}
            category={r.category}
            productCount={r.productCount}
            viewCount={r.viewCount}
            createdAt={r.createdAt}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="w-16 h-16 rounded-full bg-surface-800 flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-surface-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-white mb-2">No research yet</h2>
        <p class="text-surface-400 mb-6">Be the first to research a product!</p>
      </div>
    )}

    {/* Pagination */}
    {allResearch.length === perPage && (
      <div class="flex justify-center mt-8 gap-2">
        {page > 1 && (
          <a href={`/research?page=${page - 1}${searchQuery ? `&q=${encodeURIComponent(searchQuery)}` : ''}`}
            class="px-4 py-2 bg-surface-800 hover:bg-surface-700 text-surface-300 rounded-lg text-sm transition-colors">
            Previous
          </a>
        )}
        <a href={`/research?page=${page + 1}${searchQuery ? `&q=${encodeURIComponent(searchQuery)}` : ''}`}
          class="px-4 py-2 bg-surface-800 hover:bg-surface-700 text-surface-300 rounded-lg text-sm transition-colors">
          Next
        </a>
      </div>
    )}
  </div>
</Layout>
