---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Blog" description="Tech articles on IT, networking, homelabs, and more.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Blog</h1>
    <p class="text-surface-400 mb-8">Tech articles, guides, and opinions from the trenches.</p>

    <div class="text-center py-20">
      <div class="w-16 h-16 rounded-full bg-surface-800 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-surface-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold text-white mb-2">Blog coming soon</h2>
      <p class="text-surface-400">We're migrating 90+ articles on IT, networking, homelabs, and security. Check back shortly.</p>
    </div>
  </div>
</Layout>
