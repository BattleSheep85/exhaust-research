---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.astro';
import ResearchCard from '../components/ResearchCard.astro';
import { getDb } from '../lib/db';
import { research, products } from '../../db/schema';
import { desc, eq, sql } from 'drizzle-orm';

const db = getDb(Astro.locals.runtime.env.DB);

// Get recent completed research with product counts
const recentResearch = await db
  .select({
    id: research.id,
    slug: research.slug,
    query: research.query,
    summary: research.summary,
    category: research.category,
    viewCount: research.viewCount,
    createdAt: research.createdAt,
    productCount: sql<number>`(SELECT COUNT(*) FROM products WHERE products.research_id = ${research.id})`,
  })
  .from(research)
  .where(eq(research.status, 'complete'))
  .orderBy(desc(research.createdAt))
  .limit(6);

const popularResearch = await db
  .select({
    id: research.id,
    slug: research.slug,
    query: research.query,
    summary: research.summary,
    category: research.category,
    viewCount: research.viewCount,
    createdAt: research.createdAt,
    productCount: sql<number>`(SELECT COUNT(*) FROM products WHERE products.research_id = ${research.id})`,
  })
  .from(research)
  .where(eq(research.status, 'complete'))
  .orderBy(desc(research.viewCount))
  .limit(6);
---

<Layout title="AI-Powered Product Research">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary-950/50 to-surface-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary-900/20 via-transparent to-transparent"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-600/10 border border-primary-600/20 text-primary-400 text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Powered by AI
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-6">
          Product research,
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-primary-600">exhausted.</span>
        </h1>

        <p class="text-lg sm:text-xl text-surface-400 max-w-2xl mx-auto mb-10">
          We scrape dozens of sources, feed it all to AI, and give you brutally honest
          product comparisons. No fluff. No sponsored picks. Just the truth.
        </p>

        <SearchBar size="large" />

        <div class="flex flex-wrap items-center justify-center gap-3 mt-6 text-sm text-surface-500">
          <span>Try:</span>
          <a href="/research/new?q=best+mechanical+keyboard+under+100" class="px-3 py-1 rounded-full bg-surface-800 hover:bg-surface-700 text-surface-300 transition-colors">mechanical keyboards</a>
          <a href="/research/new?q=best+home+NAS+for+2026" class="px-3 py-1 rounded-full bg-surface-800 hover:bg-surface-700 text-surface-300 transition-colors">home NAS</a>
          <a href="/research/new?q=best+budget+4k+monitor" class="px-3 py-1 rounded-full bg-surface-800 hover:bg-surface-700 text-surface-300 transition-colors">4K monitors</a>
          <a href="/research/new?q=best+mesh+wifi+system+2026" class="px-3 py-1 rounded-full bg-surface-800 hover:bg-surface-700 text-surface-300 transition-colors">mesh WiFi</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-bold text-white text-center mb-12">How it works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      <div class="text-center">
        <div class="w-12 h-12 rounded-xl bg-primary-600/20 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">1. Ask anything</h3>
        <p class="text-surface-400 text-sm">Type a product question in plain English. Be as specific or broad as you want.</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 rounded-xl bg-primary-600/20 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">2. We go deep</h3>
        <p class="text-surface-400 text-sm">AI scrapes Reddit, reviews, forums, and specs. Dozens of sources, analyzed in seconds.</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 rounded-xl bg-primary-600/20 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">3. Get answers</h3>
        <p class="text-surface-400 text-sm">Ranked products, honest pros/cons, spec tables, and a clear verdict. No sponsored BS.</p>
      </div>
    </div>
  </section>

  <!-- Recent Research -->
  {recentResearch.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-white">Recent research</h2>
        <a href="/research" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors">
          View all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {recentResearch.map((r) => (
          <ResearchCard
            slug={r.slug}
            query={r.query}
            summary={r.summary}
            category={r.category}
            productCount={r.productCount}
            viewCount={r.viewCount}
            createdAt={r.createdAt}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Popular Research -->
  {popularResearch.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-white">Most popular</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {popularResearch.map((r) => (
          <ResearchCard
            slug={r.slug}
            query={r.query}
            summary={r.summary}
            category={r.category}
            productCount={r.productCount}
            viewCount={r.viewCount}
            createdAt={r.createdAt}
          />
        ))}
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-gradient-to-r from-primary-950 to-primary-900 rounded-2xl p-8 sm:p-12 text-center border border-primary-800/50">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Stop guessing. Start knowing.</h2>
      <p class="text-primary-200 mb-8 max-w-xl mx-auto">Every research result is saved and shareable. Build your knowledge base, one product at a time.</p>
      <SearchBar size="compact" placeholder="Research a product..." />
    </div>
  </section>
</Layout>
