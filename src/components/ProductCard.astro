---
interface Props {
  name: string;
  brand: string | null;
  price: number | null;
  rating: number | null;
  pros: string[];
  cons: string[];
  verdict: string | null;
  rank: number | null;
  bestFor: string | null;
  affiliateUrl: string | null;
  specs: Record<string, string>;
}

const { name, brand, price, rating, pros, cons, verdict, rank, bestFor, affiliateUrl, specs } = Astro.props;

function renderStars(rating: number): string {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.5 ? 1 : 0;
  return '★'.repeat(full) + (half ? '½' : '') + '☆'.repeat(5 - full - half);
}

const rankBadgeColors: Record<number, string> = {
  1: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  2: 'bg-surface-400/20 text-surface-300 border-surface-400/30',
  3: 'bg-amber-700/20 text-amber-500 border-amber-700/30',
};
---

<article class="bg-surface-900 border border-surface-800 rounded-xl overflow-hidden hover:border-surface-600 transition-all">
  <div class="p-6">
    <div class="flex items-start justify-between gap-3 mb-4">
      <div>
        {rank && (
          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold border mb-2 ${rankBadgeColors[rank] ?? 'bg-surface-700/20 text-surface-400 border-surface-700/30'}`}>
            #{rank}
          </span>
        )}
        <h3 class="text-white font-bold text-lg">{name}</h3>
        {brand && <p class="text-surface-400 text-sm">{brand}</p>}
      </div>
      <div class="text-right shrink-0">
        {price && (
          <p class="text-2xl font-bold text-white">${price.toLocaleString()}</p>
        )}
        {rating && (
          <p class="text-yellow-400 text-sm mt-1">
            {renderStars(rating)} <span class="text-surface-500">{rating}</span>
          </p>
        )}
      </div>
    </div>

    {bestFor && (
      <div class="mb-4">
        <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-primary-600/20 text-primary-400 border border-primary-600/20">
          Best for: {bestFor}
        </span>
      </div>
    )}

    {verdict && (
      <p class="text-surface-300 text-sm mb-4 italic border-l-2 border-primary-600 pl-3">
        {verdict}
      </p>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      {pros.length > 0 && (
        <div>
          <h4 class="text-success font-semibold text-xs uppercase tracking-wide mb-2">Pros</h4>
          <ul class="space-y-1">
            {pros.map((pro) => (
              <li class="text-surface-300 text-sm flex items-start gap-2">
                <svg class="w-4 h-4 text-success shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {pro}
              </li>
            ))}
          </ul>
        </div>
      )}
      {cons.length > 0 && (
        <div>
          <h4 class="text-danger font-semibold text-xs uppercase tracking-wide mb-2">Cons</h4>
          <ul class="space-y-1">
            {cons.map((con) => (
              <li class="text-surface-300 text-sm flex items-start gap-2">
                <svg class="w-4 h-4 text-danger shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                {con}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    {Object.keys(specs).length > 0 && (
      <details class="group mb-4">
        <summary class="cursor-pointer text-sm font-medium text-surface-400 hover:text-white transition-colors flex items-center gap-2">
          <svg class="w-4 h-4 group-open:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          Specifications
        </summary>
        <div class="mt-3 bg-surface-800/50 rounded-lg p-3">
          <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
            {Object.entries(specs).map(([key, value]) => (
              <Fragment>
                <dt class="text-surface-500">{key}</dt>
                <dd class="text-surface-200">{value}</dd>
              </Fragment>
            ))}
          </dl>
        </div>
      </details>
    )}

    {affiliateUrl && (
      <a
        href={affiliateUrl}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 hover:bg-primary-500 text-white text-sm font-semibold rounded-lg transition-colors"
      >
        View Deal
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
  </div>
</article>
