---
interface Props {
  size?: 'large' | 'compact';
  placeholder?: string;
}

const { size = 'large', placeholder = 'What product are you researching? e.g. "best NAS under $500"' } = Astro.props;
const isLarge = size === 'large';
---

<form action="/research/new" method="GET" class="w-full">
  <div class={`relative group ${isLarge ? 'max-w-3xl mx-auto' : 'max-w-xl'}`}>
    <div class="absolute inset-0 bg-primary-600/20 rounded-2xl blur-xl group-focus-within:bg-primary-600/30 transition-all"></div>
    <div class="relative flex items-center bg-surface-900 border border-surface-700 rounded-2xl focus-within:border-primary-500 transition-colors">
      <svg class={`${isLarge ? 'ml-5 w-6 h-6' : 'ml-4 w-5 h-5'} text-surface-400 shrink-0`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        type="text"
        name="q"
        placeholder={placeholder}
        required
        aria-label="Search query"
        class={`flex-1 bg-transparent border-none outline-none text-white placeholder-surface-500 ${isLarge ? 'px-4 py-5 text-lg' : 'px-3 py-3 text-base'}`}
      />
      <button
        type="submit"
        class={`${isLarge ? 'mr-3 px-6 py-3' : 'mr-2 px-4 py-2'} bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-xl transition-colors shrink-0`}
      >
        Research
      </button>
    </div>
  </div>
</form>
