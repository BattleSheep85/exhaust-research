---
interface Props {
  slug: string;
  query: string;
  summary: string | null;
  category: string | null;
  productCount: number;
  viewCount: number;
  createdAt: Date;
}

const { slug, query, summary, category, productCount, viewCount, createdAt } = Astro.props;

function timeAgo(date: Date): string {
  const seconds = Math.floor((Date.now() - date.getTime()) / 1000);
  if (seconds < 60) return 'just now';
  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;
  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;
  return `${Math.floor(seconds / 86400)}d ago`;
}
---

<a href={`/research/${slug}`} class="block group">
  <article class="bg-surface-900 border border-surface-800 rounded-xl p-5 hover:border-surface-600 transition-all hover:bg-surface-800/50">
    <div class="flex items-start justify-between gap-3 mb-3">
      {category && (
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-600/20 text-primary-400">
          {category}
        </span>
      )}
      <span class="text-xs text-surface-500 shrink-0">{timeAgo(createdAt)}</span>
    </div>
    <h3 class="text-white font-semibold text-lg mb-2 group-hover:text-primary-400 transition-colors line-clamp-2">
      {query}
    </h3>
    {summary && (
      <p class="text-surface-400 text-sm line-clamp-2 mb-3">{summary}</p>
    )}
    <div class="flex items-center gap-4 text-xs text-surface-500">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
        {productCount} products
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        {viewCount} views
      </span>
    </div>
  </article>
</a>
